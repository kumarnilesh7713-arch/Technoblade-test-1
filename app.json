{
  "expo": {
    "name": "Day 1",
    "slug": "day-1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "day1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "backgroundColor": "#0A0E1A",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.day1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Day 1 uses your location to record your run, ride, and walk routes."
      }
    },
    "android": {
      "package": "com.yourname.day1",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Day 1 uses your location to record your run, ride, and walk routes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
